# Example environment for the backend. Copy relevant values into your own .env (gitignored),
# docker-compose environment, or use `dotnet user-secrets` for local runs. NEVER commit real secrets.

# Data source backing ISalesRepository:
#   Mock = the local sap-mock service (default, no secrets needed)
#   Sap  = real SAP S/4HANA OData (Business Accelerator Hub sandbox)
SalesSource=Mock

# Required ONLY when SalesSource=Sap. Free API key from https://api.sap.com (Business
# Accelerator Hub → your settings → API keys). THIS IS A SECRET — never commit the real value.
Sap__ApiKey=

# Optional: override the SAP OData base URL (defaults to the API_SALES_ORDER_SRV sandbox).
Sap__BaseUrl=https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_SALES_ORDER_SRV/

# Mock source base URL (used when SalesSource=Mock). In docker-compose this is http://sap-mock:8080.
SapMock__BaseUrl=http://sap-mock:8080
